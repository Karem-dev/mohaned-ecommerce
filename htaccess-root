<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Map existing public assets (CSS, JS, and now Storage which we copied there)
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.+)$ public/$1 [L]

    # 2. Handle everything else via Laravel's index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ public/index.php [L]
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Force everything starting with /storage to the public storage folder
    RewriteRule ^storage/(.*)$ public/storage/$1 [L]

    # 2. Map existing public assets (CSS, JS, etc.)
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.+)$ public/$1 [L]

    # 3. Handle everything else via Laravel's index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    # We remove the !-d check to fix the 403 error on the home directory
    RewriteRule ^ public/index.php [L]
</IfModule>

# Root .gitignore for Rose E-commerce

# Dependencies
**/node_modules/
**/vendor/

# Environments
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env.backup
**/.env.production

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Files
.DS_Store
Thumbs.db

# Laravel Specific
backend/storage/*.key
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
backend/storage/logs/*
backend/public/storage
backend/public/hot
backend/public/build
backend/.phpunit.result.cache

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Misc
backend/debug_output.json
backend/slugs.txt
